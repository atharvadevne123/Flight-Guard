# Flight-Guard environment variables
# Copy to .env and fill in values

# Database
DATABASE_URL=sqlite:///./flight_guard.db
# DATABASE_URL=postgresql://flightguard:password@localhost:5432/flightguard

# Model paths
MODEL_PATH=model.joblib
METRICS_PATH=metrics.json

# Retraining thresholds
RETRAIN_AUC_GATE=0.70
RETRAIN_MIN_SAMPLES=200

# API settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# Logging
LOG_LEVEL=INFO
